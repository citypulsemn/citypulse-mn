# ── Database: Supabase or Neon (any standard Postgres connection string) ──
# Supabase: Project Settings → Database → Connection string → "Transaction" (pooled)
# Neon:     Dashboard → Connection Details → pooled connection string
# Unset → the site serves bundled sample data.
DATABASE_URL=

# ── Map (browser) ──
# Public Mapbox token (pk.*), restricted to your domain.
NEXT_PUBLIC_MAPBOX_TOKEN=

# ── Pipeline (server-side only; NOT needed to run the website) ──
# Anthropic API key for the research agents.
ANTHROPIC_API_KEY=
# Server token for geocoding. Optional — falls back to NEXT_PUBLIC_MAPBOX_TOKEN.
MAPBOX_GEOCODING_TOKEN=
# Trigger.dev deploy/runtime key (from the Trigger.dev dashboard).
TRIGGER_SECRET_KEY=

# --- Admin dashboard (roadmap 1.5) ---
# Protects /admin with HTTP Basic auth. If ADMIN_PASSWORD is unset, /admin is locked.
ADMIN_USER=admin
ADMIN_PASSWORD=

# --- Weekly email digest (roadmap 3.1) ---
# Resend API key (resend.com) for sending. Unset → digest logs instead of sends.
RESEND_API_KEY=
# Verified sender. Must be on a domain you've verified in Resend.
DIGEST_FROM=City Pulse MN <hello@citypulsemn.com>
# Secret for signing one-click unsubscribe links. Set to a long random string.
UNSUBSCRIBE_SECRET=
# Public site origin used in email links (no trailing slash).
SITE_URL=https://citypulsemn.com
